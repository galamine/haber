{
  "name": "@haber-full/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "biome check --write ./src",
    "lint:check": "biome check ./src",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "clean": "rm -rf dist",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@haber-full/shared": "workspace:*",
    "@hono/node-server": "^2.0.2",
    "@hono/trpc-server": "^0.4.2",
    "@prisma/client": "^6.4.1",
    "@t3-oss/env-core": "^0.12.0",
    "@trpc/server": "^11.0.0",
    "argon2": "^0.31.2",
    "hono": "^4.7.5",
    "jose": "^5.9.6",
    "resend": "^4.1.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@types/node": "^22.13.4",
    "prisma": "^6.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "vitest": "^4.0.7"
  }
}
