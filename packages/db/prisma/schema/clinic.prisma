model Clinic {
  id           String      @id @default(cuid())
  name         String
  address      String
  contactName  String
  contactPhone String
  contactEmail String
  timezone     String      @default("Asia/Kolkata")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?

  departments  Department[]
  sensoryRooms SensoryRoom[]
  users        User[]
  children     Child[]

  @@map("clinic")
}