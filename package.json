{
	"name": "habe-final",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"type": "module",
	"scripts": {
		"dev": "pnpm -r dev",
		"build": "pnpm -r build",
		"check-types": "pnpm -r check-types",
		"dev:web": "pnpm --filter web dev",
		"dev:server": "pnpm --filter server dev",
		"db:push": "pnpm --filter @habe-final/db db:push",
		"db:studio": "pnpm --filter @habe-final/db db:studio",
		"db:generate": "pnpm --filter @habe-final/db db:generate",
		"db:migrate": "pnpm --filter @habe-final/db db:migrate",
		"db:start": "pnpm --filter @habe-final/db db:start",
		"db:watch": "pnpm --filter @habe-final/db db:watch",
		"db:stop": "pnpm --filter @habe-final/db db:stop",
		"db:down": "pnpm --filter @habe-final/db db:down",
		"check": "biome check --write .",
		"prepare": "husky"
	},
	"dependencies": {
		"@habe-final/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@habe-final/config": "workspace:*",
		"@types/node": "catalog:",
		"typescript": "catalog:",
		"husky": "^9.1.7",
		"lint-staged": "^16.1.2"
	},
	"packageManager": "pnpm@10.13.1",
	"lint-staged": {
		"**/*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,vue,astro,svelte}": ""
	}
}
